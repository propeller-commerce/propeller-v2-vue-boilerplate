# Copy this file to .env and fill in your own values. .env is gitignored;
# this example file is NOT.

# GraphQL backend — proxied through the Vite dev server at /api/graphql so the
# browser never speaks to upstream directly. The proxy target + API key are
# server-only.
VITE_GRAPHQL_ENDPOINT=/api/graphql
VITE_GRAPHQL_PROXY_TARGET=https://api.example.com/v2/graphql
VITE_API_KEY=your_api_key_here
VITE_ORDER_EDITOR_API_KEY=your_order_editor_api_key_here

# Catalog defaults
VITE_BASE_CATEGORY_ID=1
# Channel orders/quotes are placed on. Account order/quote lists filter by it,
# so a wrong value returns zero results. Match your Propeller environment.
VITE_CHANNEL_ID=1
VITE_MENU_DEPTH=3
VITE_ANONYMOUS_USER_ID=0

# ── Machines / spare parts ──────────────────────────────────────────────────
# External system the machine ("installation") ids belong to, paired with each
# id as machine(source:, sourceId:). The id list is read at runtime from the
# contact's company MY_INSTALLATIONS track attribute (already in
# configuration.companyTrackAttributes). Leave unset to disable the machines
# root. Tree language is usually EN while parts stay in the storefront language.
VITE_BOILERPLATE_MACHINE_SOURCE=
VITE_BOILERPLATE_MACHINE_LANGUAGE=EN

# Localisation
VITE_DEFAULT_LANGUAGE=NL
VITE_URL_PATTERN=page/id/slug
VITE_TIMEOUT=30000

# Catalog visibility mode — kebab-case: 'open' | 'semi-closed' | 'closed'.
# 'semi-closed' hides prices for anonymous users and omits the `offers` block
# from JSON-LD output. Defaults to 'open' if unset.
VITE_PORTAL_MODE=open

# Absolute origin of this site (no trailing slash). Used to build absolute URLs
# in schema.org / JSON-LD payloads emitted by ProductJsonLd / ClusterJsonLd /
# ItemListJsonLd. When unset the JSON-LD emits path-only URLs.
VITE_SITE_URL=https://shop.example.com

# Server-side SSR data fetching (read by server.js / src/lib/server.ts via
# process.env). Vite statically strips process.env.VITE_* in the SSR transform,
# so the seam needs its own vars.
SSR_GRAPHQL_ENDPOINT=https://api.example.com/v2/graphql
SSR_API_KEY=your_api_key_here
SSR_ORDER_EDITOR_API_KEY=your_order_editor_api_key_here

# Shared secret gating POST /api/revalidate. Unset = endpoint returns 503
# (fails closed).
REVALIDATE_SECRET=replace_with_a_long_random_string

# ── Payments (Mollie PSP) ───────────────────────────────────────────────────
# Active payment provider. 'mollie' turns on the Mollie checkout flow (place
# order → hosted checkout → three-state thank-you). Anything else keeps the
# previous "place order → straight to thank-you" behaviour.
PAYMENT_PROVIDER=mollie
# Client mirror — read by the checkout view via import.meta.env. Keep in sync.
VITE_PAYMENT_PROVIDER=mollie

# Mollie API keys. SERVER-ONLY (no VITE_ prefix → never bundled into the
# browser). Get these from the Mollie Dashboard (Developers → API keys).
MOLLIE_LIVE_KEY=live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_TEST_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# true → use the test key, false → use the live key. Defaults to true.
MOLLIE_TEST_MODE=true

# Methods that settle ON ACCOUNT and do NOT go through a PSP. Comma-separated,
# case-insensitive. For these the order is placed straight to NEW; every other
# method goes through Mollie. Defaults to "REKENING,ON_ACCOUNT" when unset.
ON_ACCOUNT_PAYMENTS=REKENING,ON_ACCOUNT
# Client mirror — keep in sync with ON_ACCOUNT_PAYMENTS.
VITE_ON_ACCOUNT_PAYMENTS=REKENING,ON_ACCOUNT

# ISO 4217 currency CODE sent to Mollie (e.g. EUR/USD/GBP) — the 3-letter code,
# NOT a display symbol. Defaults to EUR.
VITE_CURRENCY_CODE=EUR

# Mollie POSTs its webhook to VITE_SITE_URL + /api/mollie/webhook, which must be
# PUBLICLY reachable over HTTPS — Mollie cannot reach localhost or LAN IPs. In
# dev, expose the server with a tunnel (cloudflared / ngrok) and either point
# VITE_SITE_URL at the tunnel, or set MOLLIE_WEBHOOK_URL below. Accepts a bare
# origin (we append /api/mollie/webhook) or the full webhook URL.
# MOLLIE_WEBHOOK_URL=https://your-tunnel.trycloudflare.com

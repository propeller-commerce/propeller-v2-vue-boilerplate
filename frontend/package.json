{
  "name": "propeller-vue",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "locales:build": "node scripts/build-locales-registry.mjs",
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "node server.js",
    "predev": "node scripts/build-locales-registry.mjs",
    "build": "npm run build:client && npm run build:server",
    "prebuild": "node scripts/build-locales-registry.mjs",
    "build:client": "vite build --ssrManifest --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.ts --outDir dist/server",
    "build:check": "vue-tsc -b && npm run build",
    "preview": "cross-env NODE_ENV=production node server.js",
    "clean": "powershell -Command \"Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@propeller-commerce/propeller-sdk-v2": "^0.11.1",
    "@unhead/vue": "^2.1.15",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "lodash.debounce": "^4.0.8",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.0",
    "pinia": "^3.0.4",
    "propeller-v2-vue-ui": "github:propeller-commerce/propeller-v2-vue-ui#master",
    "qs": "^6.15.0",
    "swiper": "^12.1.3",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.32",
    "vue-hot-toast": "^0.0.1-rc.4",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^24.12.2",
    "@types/qs": "^6.15.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vue-tsc": "^3.2.6"
  }
}
